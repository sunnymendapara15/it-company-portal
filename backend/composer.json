{
  "name": "it-company-portal/backend",
  "type": "project",
  "description": "Laravel API for IT company authentication",
  "keywords": ["laravel", "sanctum", "api", "it company"],
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "laravel/framework": "^11.0",
    "laravel/sanctum": "^3.3"
  },
  "require-dev": {
    "fakerphp/faker": "^1.21",
    "phpunit/phpunit": "^10.0",
    "mockery/mockery": "^1.6"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "test": "phpunit"
  }
}
